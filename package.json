{
  "name": "caedora",
  "version": "0.1.0",
  "private": true,
  "license": "MPL-2.0",
  "description": "Privacy-first Open Knowledge Format workspace and local-first desktop assistant.",
  "author": "William F. Clarke",
  "homepage": "https://caedora.app",
  "main": "electron/main.cjs",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "desktop:dev": "concurrently -k -s first -n next,electron \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
    "web:standalone": "next build && node scripts/prepare-desktop-app.mjs --standalone-only",
    "desktop:build:web": "next build && node scripts/prepare-desktop-app.mjs",
    "desktop:pack": "npm run desktop:build:web && electron-builder --dir --publish never",
    "desktop:dist": "npm run desktop:build:web && electron-builder --publish never",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "screenshots": "node scripts/generate-product-screenshots.mjs",
    "postinstall": "electron-builder install-app-deps",
    "test:desktop": "playwright test --config=playwright.desktop.config.ts",
    "test:unit": "npm test --workspace packages/caedora-mcp",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.0",
    "@assistant-ui/react-markdown": "^0.14.0",
    "@clerk/nextjs": "^7.5.9",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tiptap/extension-character-count": "^2.11.0",
    "@tiptap/extension-color": "^2.11.0",
    "@tiptap/extension-highlight": "^2.11.0",
    "@tiptap/extension-image": "^2.11.0",
    "@tiptap/extension-link": "^2.11.0",
    "@tiptap/extension-placeholder": "^2.11.0",
    "@tiptap/extension-subscript": "^2.11.0",
    "@tiptap/extension-superscript": "^2.11.0",
    "@tiptap/extension-table": "^2.27.2",
    "@tiptap/extension-table-cell": "^2.27.2",
    "@tiptap/extension-table-header": "^2.27.2",
    "@tiptap/extension-table-row": "^2.27.2",
    "@tiptap/extension-task-item": "^2.27.2",
    "@tiptap/extension-task-list": "^2.27.2",
    "@tiptap/extension-text-align": "^2.11.0",
    "@tiptap/extension-text-style": "^2.11.0",
    "@tiptap/extension-typography": "^2.11.0",
    "@tiptap/extension-underline": "^2.11.0",
    "@tiptap/react": "^2.11.0",
    "@tiptap/starter-kit": "^2.11.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "diff": "^5.2.0",
    "idb": "^8.0.0",
    "ignore": "^7.0.5",
    "isomorphic-git": "^1.27.0",
    "lucide-react": "^0.511.0",
    "next": "^15.3.3",
    "next-themes": "^0.4.6",
    "node-llama-cpp": "^3.18.1",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "sharp": "^0.34.4",
    "tailwind-merge": "^2.6.0",
    "tw-animate-css": "^1.2.5",
    "tw-shimmer": "^0.4.11",
    "unified": "^11.0.5",
    "vaul": "^1.1.2",
    "yaml": "^2.9.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@tailwindcss/postcss": "^4.1.4",
    "@types/diff": "^5.2.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "^15.3.3",
    "tailwindcss": "^4.1.4",
    "typescript": "^5",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "app.caedora.desktop",
    "productName": "Caedora",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "lib/ai/argus-context.json",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": ".desktop-app/server.js",
        "to": "app/server.js"
      },
      {
        "from": ".desktop-app/package.json",
        "to": "app/package.json"
      },
      {
        "from": ".desktop-app/.next",
        "to": "app/.next"
      },
      {
        "from": ".desktop-app/public",
        "to": "app/public"
      },
      {
        "from": ".desktop-app/node_modules",
        "to": "app/node_modules"
      }
    ],
    "asarUnpack": [
      "node_modules/node-llama-cpp/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Caedora-Windows-${arch}-Setup.${ext}",
      "icon": "electron/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "artifactName": "Caedora-macOS-${arch}.${ext}",
      "icon": "electron/icon.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
