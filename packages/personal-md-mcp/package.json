{
  "name": "personal-md-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for personal-md vaults — read, search, and maintain your vault from any MCP client.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "personal-md-mcp": "./dist/cli.js"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --test --experimental-strip-types 'src/**/*.test.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "personal-md",
    "markdown",
    "notes",
    "vault"
  ],
  "engines": {
    "node": ">=20"
  }
}
