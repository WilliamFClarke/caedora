{
  "name": "caedora-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for Caedora vaults — read, search, and maintain your vault from any MCP client.",
  "license": "MIT",
  "homepage": "https://caedora.app",
  "type": "module",
  "bin": {
    "caedora-mcp": "./dist/cli.js"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "tsx --test 'src/**/*.test.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.22.1"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "caedora",
    "markdown",
