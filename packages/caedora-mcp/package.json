{
  "name": "caedora-mcp",
  "version": "0.2.0",
  "description": "Model Context Protocol server for reading and maintaining Open Knowledge Format bundles.",
  "license": "MPL-2.0",
  "homepage": "https://caedora.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WilliamFClarke/caedora.git",
    "directory": "packages/caedora-mcp"
  },
  "bugs": {
    "url": "https://github.com/WilliamFClarke/caedora/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "caedora-mcp": "dist/cli.js"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/tools/write.test.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "yaml": "^2.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "caedora",
    "markdown",
    "concepts",
    "knowledge-bundle",
    "open-knowledge-format",
    "okf"
  ],
  "engines": {
    "node": ">=20"
  }
}
