# GitHub OAuth App credentials (app-level config — not user data, safe as server env vars)
# 1. Go to https://github.com/settings/developers → OAuth Apps → New OAuth App
# 2. Homepage URL: https://your-app.vercel.app
# 3. Authorization callback URL: https://your-app.vercel.app/api/auth/github/callback
# 4. Add both values below to your Vercel project environment variables
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
